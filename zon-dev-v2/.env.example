SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
MAPBOX_TOKEN=pk.your-mapbox-token
# Place search — Korea uses Naver, global uses Google
# Naver: https://developers.naver.com/apps (Local Search API)
# Naver Search API (developers.naver.com) → Local Search place results
NAVER_CLIENT_ID=your-naver-search-client-id
NAVER_CLIENT_SECRET=your-naver-search-client-secret
# Naver Cloud Platform (console.ncloud.com) → Maps: Reverse Geocoding
NAVER_MAP_CLIENT_ID=your-ncp-client-id
NAVER_MAP_CLIENT_SECRET=your-ncp-client-secret
# Google: https://console.cloud.google.com (Places API — global fallback only)
GOOGLE_PLACES_API_KEY=your-google-places-key
# Firebase: Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----
